# Required for pyannote diarization
HF_TOKEN=hf_your_token_here

# Optional runtime overrides
SCRIBE_TRANSCRIPTION_BACKEND=auto
# Preferred MLX model for Apple Silicon Macs. `SCRIBE_MODEL_NAME` is also supported as a legacy alias.
SCRIBE_MLX_MODEL_NAME=mlx-community/whisper-large-v3-turbo
# Preferred Faster-Whisper model for non-Apple-Silicon systems.
SCRIBE_FASTER_WHISPER_MODEL=large-v3
# Example default only. Any local chat-capable Ollama model can be used.
SCRIBE_DEFAULT_LLM=gemma3:27b
SCRIBE_DEFAULT_SAVE_DIR=~/Downloads/ScribeTranscripts
SCRIBE_MAX_SPEAKERS=8

# Gradio runtime config
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
GRADIO_DEBUG=false

# Keep remote Hugging Face tokenizer fetch off by default (avoids incidental 404s)
SCRIBE_ENABLE_REMOTE_TOKENIZER_LOOKUP=false

# Common cloud platforms provide PORT automatically
PORT=7860
